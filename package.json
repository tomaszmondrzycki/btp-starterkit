{
  "name": "btp-starterkit",
  "version": "1.0.0",
  "description": "Welcome to your new CAP project.",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "scripts": {
    "start": "cds watch",
    "test": "node -r ts-node/register node_modules/jest/bin/jest.js",
    "watch-customer": "cds watch --open btp.starterkit.customer/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "dependencies": {
    "@cap-js/postgres": "^2",
    "@cap-js/sqlite": "^2.4.0",
    "@sap/cds": "^9",
    "sqlite3": "^5"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.16.0",
    "@sap/cds-dk": "^9",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "cds-plugin-ui5": "^0.17.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite"
      }
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/customer"
  ]
}
