{
  "name": "btp-starterkit",
  "version": "1.0.0",
  "description": "Welcome to your new CAP project.",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "scripts": {
    "start": "cds watch",
    "test": "node -r ts-node/register node_modules/jest/bin/jest.js",
    "watch-customer": "cds watch --open btp.starterkit.customer/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy btp-starterkit --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "dependencies": {
    "@cap-js/postgres": "^2.3.0",
    "@sap/cds": "^9.9.1",
    "@sap/xssec": "^4.13.0",
    "sqlite3": "^5"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.16.0",
    "@sap/cds-dk": "^9",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.0",
    "cds-plugin-ui5": "^0.17.0",
    "jest": "^29.7.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "postgres"
      }
    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/customer"
  ]
}
