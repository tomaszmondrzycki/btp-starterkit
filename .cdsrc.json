{
  "build": {
    "[production]": {
      "target": "gen",
      "tasks": [
        {
          "for": "nodejs",
          "src": "srv",
          "options": {
            "model": [
              "db",
              "srv"
            ]
          }
        },
        {
          "for": "typescript"
        },
        {
          "for": "postgres",
          "src": "db",
          "options": {
            "model": [
              "db",
              "srv"
            ]
          }
        }
      ]
    }
  }
}